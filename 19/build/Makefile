atm/tests/test_journal.s: atm/tests/test_journal.cpp.s
.PHONY : atm/tests/test_journal.s

# target to generate assembly for a file
atm/tests/test_journal.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_journal.dir/build.make CMakeFiles/test_journal.dir/atm/tests/test_journal.cpp.s
.PHONY : atm/tests/test_journal.cpp.s

atm/transaction.o: atm/transaction.cpp.o
.PHONY : atm/transaction.o

# target to build an object file
atm/transaction.cpp.o:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/atm.dir/build.make CMakeFiles/atm.dir/atm/transaction.cpp.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_card.dir/build.make CMakeFiles/test_card.dir/atm/transaction.cpp.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_account.dir/build.make CMakeFiles/test_account.dir/atm/transaction.cpp.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_journal.dir/build.make CMakeFiles/test_journal.dir/atm/transaction.cpp.o
.PHONY : atm/transaction.cpp.o

atm/transaction.i: atm/transaction.cpp.i
.PHONY : atm/transaction.i

# target to preprocess a source file
atm/transaction.cpp.i:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/atm.dir/build.make CMakeFiles/atm.dir/atm/transaction.cpp.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_card.dir/build.make CMakeFiles/test_card.dir/atm/transaction.cpp.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_account.dir/build.make CMakeFiles/test_account.dir/atm/transaction.cpp.i
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_journal.dir/build.make CMakeFiles/test_journal.dir/atm/transaction.cpp.i
.PHONY : atm/transaction.cpp.i

atm/transaction.s: atm/transaction.cpp.s
.PHONY : atm/transaction.s

# target to generate assembly for a file
atm/transaction.cpp.s:
	$(MAKE) $(MAKESILENT) -f CMakeFiles/atm.dir/build.make CMakeFiles/atm.dir/atm/transaction.cpp.s
	$(MAKE) $(MAKESILENT) -f CMakeFiles/test_card.dir/build.make CMakeFiles/test_card.dir/atm/transaction.cpp.s
